racy\": retrieval_accuracy,\n","            \"defect_label_precision\": defect_label_precision,\n","            \"defect_label_recall\": defect_label_recall,\n","            \"parameter_accuracy\": parameter_accuracy,\n","            \"latency\": latency,\n","            \"answer\": response\n","        })\n","\n","    return pd.DataFrame(results)"],"metadata":{"id":"uJ4q5KNNz6in"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["## Run Benchmark Evaluation\n","df = evaluate_graph_rag(graph_rag_qa, benchmark, k=5)\n","df"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"7k_uqOHAmqEM","executionInfo":{"status":"ok","timestamp":1774652844847,"user_tz":0,"elapsed":55740,"user":{"displayName":"Muhammad Awan","userId":"05534583974233650953"}},"outputId":"c10b57a2-a187-4b26-ee78-dbd487c8d43b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["Setting `pad_token_id` to `eos_token_id`:2 for open-end generation.\n"]},{"output_type":"stream","name":"stdout","text":["Matched graph nodes: ['laser power', 'keyhole']\n","\n","=== Retrieved Evidence ===\n","final_cleaned_40_chunk_2 | defects: ['porosity', 'keyhole']\n","final_cleaned_16_chunk_12 | defects: ['porosity', 'keyhole']\n","final_cleaned_29_chunk_21 | defects: ['porosity', 'keyhole']\n","final_cleaned_29_chunk_14 | defects: ['porosity']\n","final_cleaned_29_chunk_20 | defects: ['porosity', 'lack_of_fusion', 'keyhole']\n"]},{"output_type":"stream","name":"stderr","text":["Setting `pad_token_id` to `eos_token_id`:2 for open-end generation.\n"]},{"output_type":"stream","name":"stdout","text":["Matched graph nodes: ['scan speed', 'lack_of_fusion']\n","\n","=== Retrieved Evidence ===\n","final_cleaned_34_chunk_26 | defects: ['porosity', 'surface_defect']\n","final_cleaned_16_chunk_13 | defects: ['porosity', 'keyhole']\n","final_cleaned_32_chunk_7 | defects: ['keyhole', 'lack_of_fusion', 'surface_defect']\n","final_cleaned_34_chunk_11 | defects: