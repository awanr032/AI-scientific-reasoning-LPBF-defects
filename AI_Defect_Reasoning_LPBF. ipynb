"\n","    prompt = f\"\"\"\n","Answer the question using only the evidence below.\n","If evidence is insufficient, say so clearly.\n","\n","Question:\n","{question}\n","\n","Evidence:\n","{context}\n","\n","Answer:\n","\"\"\"\n","\n","    inputs = tokenizer(prompt, return_tensors=\"pt\", truncation=True, max_length=3000).to(model.device)\n","\n","    outputs = model.generate(\n","        **inputs,\n","        max_new_tokens=250,\n","        do_sample=True,\n","        temperature=0.2\n","    )\n","\n","    answer = tokenizer.decode(outputs[0], skip_special_tokens=True)\n","    return answer.split(\"Answer:\")[-1].strip()"],"metadata":{"id":"nwXtOHVKmW9H"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["## End-to-End Question Answering\n","def graph_rag_qa(question, k=5):\n","    results = graph_rag_retrieve(question, top_k=k)\n","\n","    print(\"\\n=== Retrieved Evidence ===\")\n","    for r in results:\n","        print(r[\"chunk_id\"], \"| defects:\", r[\"possible_defects\"])\n","\n","    answer = mistral_graph_answer(question, results)\n","\n","    return answer, results"],"metadata":{"id":"e9-lDue5mYV0"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["## Example Query\n","answer, evidence = graph_rag_qa(\n","    \"Why does high laser power lead to keyhole porosity in LPBF?\"\n",")\n","\n","print(\"\\n=== ANSWER ===\")\n","print(answer)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XndK_hUmmiLn","executionInfo":{"status":"ok","timestamp":1773275338600,"user_tz":0,"elapsed":8571,"user":{"displayName":"Muhammad Awan","userId":"05534583974233650953"}},"outputId":"c5357646-a788-4f0f-9886-f710ab723642"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["Setting `pad_token_id` to `eos_token_id`:2 for open-end generation.\n"]},{"output_type":"stream","name":"stdout","text":["Matched graph nodes: ['laser power', 'keyhole']\n","\n","=== Retrieved Evidence ===\n","final_cleaned_40_chunk_2 | defects: ['porosity', 'keyhole']\n","final_cleaned_16_chunk_12 | defects: ['porosity', 'keyhole']\n","final_cleaned_29_chunk_21 | defects: ['porosity', 'keyhole']\n","final_cleaned_29_chunk_14 | defects: ['porosity']\n","final_cleaned_29_chunk_20 | defects: ['porosity', 'lack_of_fusion', 'keyhole']\n","\n","=== ANSWER ===\n","High laser power in LPBF leads to keyhole porosity due to the deep meltpool and strong meltpool dynamics caused by the high power, which can entrap vapours in pores as the meltpool propagates forward and the vapour cavity collapses. The keyhole is subjected to axial fluctuations and radial perturbations, posing a risk for keyhole instability and collapse, resulting in the formation of a bubble in the melt pool that may get trapped by the solidification front to form a pore. These pores can act as stress concentrators and sites for crack initiation and growth, making them potentially detrimental to fatigue life and other final component mechanical properties. The keyhole porosity increases with increasing laser power and decreasing scan speed, while the pore size seems to be dependent on the input LED alone. The keyhole porosity decreases noticeably with the decrease in the strut horizontal dimension, possibly due to the change in the scan length.\n"]}]},{"cell_type":"code","source":["## Benchmark Evaluation(A small set of domain-specific questions is used to evaluate how well the system captures relationships between process parameters and defect formation)\n","\n","benchmark = [\n","\n","{\n","\"question\": \"Why does high laser power lead to keyhole porosity in LPBF?\",\n","\"expected_defects\": [\"porosity\", \"keyhole\"],\n","\"expected_parameters\": [\"laser power\"]\n","},\n","\n","{\n","\"question\": \"How does high scan speed contribute to lack of fusion defects in LPBF?\",\n","\"expected_defects\": [\"lack_of_fusion\"],\n","\"expected_parameters\": [\"scan speed\"]\n","},\n","\n","{\n","\"question\": \"Which process parameters influence porosity formation in LPBF?\",\n","\"expected_defects\": [\"porosity\"],\n","\"expected_parameters\": [\"laser power\", \"scan speed\", \"energy density\", \"hatch spacing\"]\n","},\n","\n","{\n","\"question\": \"How does hatch spacing affect lack of fusion defects?\",\n","\"expected_defects\": [\"lack_of_fusion\"],\n","\"expected_parameters\": [\"hatch spacing\"]\n","},\n","\n","{\n","\"question\": \"Why does insufficient laser power lead to lack of fusion in LPBF?\",\n","\"expected_defects\": [\"lack_of_fusion\"],\n","\"expected_parameters\": [\"laser power\"]\n","},\n","\n","{\n","\"question\": \"What role does energy density play in LPBF defect formation?\",\n","\"expected_defects\": [\"porosity\", \"lack_of_fusion\", \"keyhole\"],\n","\"expected_parameters\": [\"energy density\"]\n","},\n","\n","{\n","\"question\": \"How can layer thickness contribute to lack of fusion in LPBF?\",\n","\"expected_defects\": [\"lack_of_fusion\"],\n","\"expected_parameters\": [\"layer thickness\"]\n","},\n","\n","{\n","\"question\": \"What causes residual stress formation during LPBF?\",\n","\"expected_defects\": [\"residual_stress\"],\n","\"expected_parameters\": [\"scan strategy\", \"layer thickness\"]\n","},\n","\n","{\n","\"question\": \"Why does unstable melt pool behaviour lead to porosity?\",\n","\"expected_defects\": [\"porosity\"],\n","\"expected_parameters\": []\n","},\n","\n","{\n","\"question\": \"How do process parameters contribute to cracking in LPBF?\",\n","\"expected_defects\": [\"crack\"],\n","\"expected_parameters\": [\"laser power\", \"energy density\", \"hatch spacing\"]\n","}\n","\n","]"],"metadata":{"id":"hzXSy2JFmo9G"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["## Evaluation Function(This function evaluates the system on the benchmark questions using retrieved defect and parameter signals, along with latency.)\n","import time\n","import pandas as pd\n","from collections import Counter\n","\n","def evaluate_graph_rag(model_function, benchmark, k=5):\n","    results = []\n","\n","    for item in benchmark:\n","        question = item[\"question\"]\n","\n","        start = time.time()\n","        response, evidence = model_function(question, k)\n","        latency = time.time() - start\n","\n","        retrieved_defects_all = []\n","        retrieved_parameters_all = []\n","\n","        for ev in evidence:\n","            retrieved_defects_all += ev.get(\"possible_defects\", [])\n","            retrieved_parameters_all += ev.get(\"possible_parameters\", [])\n","\n","        defect_counts = Counter(retrieved_defects_all)\n","        parameter_counts = Counter(retrieved_parameters_all)\n","\n","        # keep only labels appearing in at least 2 chunks\n","        retrieved_defects = [d for d, c in defect_counts.items() if c >= 2]\n","        retrieved_parameters = [p for p, c in parameter_counts.items() if c >= 2]\n","\n","        expected_defects = item.get(\"expected_defects\", [])\n","        expected_parameters = item.get(\"expected_parameters\", [])\n","\n","        correct_defects = set(expected_defects).intersection(retrieved_defects)\n","        correct_params = set(expected_parameters).intersection(retrieved_parameters)\n","\n","        retrieval_accuracy = len(correct_defects) / max(len(expected_defects), 1)\n","        defect_label_precision = len(correct_defects) / max(len(retrieved_defects), 1)\n","        defect_label_recall = len(correct_defects) / max(len(expected_defects), 1)\n","\n","        if len(expected_parameters) == 0:\n","            parameter_accuracy = None\n","        else:\n","            parameter_accuracy = len(correct_params) / len(expected_parameters)\n","\n","        results.append({\n","            \"question\": question,\n","            \"retrieved_defects\": retrieved_defects,\n","            \"retrieved_defect_counts\": dict(defect_counts),\n","            \"retrieved_parameters\": retrieved_parameters,\n","            \"retrieved_parameter_counts\